# Copy this to .env.local — DO NOT commit .env.local.

# Public anon key — used in browser for normal queries against RLS-protected tables.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...your-anon-key

# Service-role key — BYPASSES RLS. Used only on the server (route handlers, server
# components, server actions). NEVER expose to the browser. Keep this in Vercel
# environment variables, not committed.
SUPABASE_SERVICE_ROLE_KEY=eyJ...your-service-role-key
