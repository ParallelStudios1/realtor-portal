{
  "expo": {
    "name": "Realtor Portal",
    "slug": "realtor-portal",
    "version": "0.1.1",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.parallelstudios.realtorportal",
      "associatedDomains": [
        "applinks:realtor-portal-ten.vercel.app"
      ],
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.parallelstudios.realtorportal",
      "permissions": [
        "android.permission.RECORD_AUDIO"
      ],
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "https",
              "host": "realtor-portal-ten.vercel.app",
              "pathPrefix": "/welcome"
            },
            {
              "scheme": "https",
              "host": "realtor-portal-ten.vercel.app",
              "pathPrefix": "/invite"
            }
          ],
          "category": ["BROWSABLE", "DEFAULT"]
        }
      ]
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-notifications",
      "expo-document-picker",
      "expo-image-picker"
    ],
    "scheme": "realtorportal",
    "extra": {
      "router": {},
      "eas": {
        "projectId": "2ec40b9d-760a-4b14-81eb-8de0f06e9fdb"
      }
    },
    "owner": "parallelstudios"
  }
}
