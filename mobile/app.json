{
  "expo": {
    "name": "Realtor Portal",
    "slug": "realtor-portal",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.parallelstudios.realtorportal",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.parallelstudios.realtorportal",
      "permissions": [
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-notifications",
      "expo-document-picker",
      "expo-image-picker"
    ],
    "scheme": "realtorportal",
    "extra": {
      "router": {},
      "eas": {
        "projectId": "2ec40b9d-760a-4b14-81eb-8de0f06e9fdb"
      }
    },
    "owner": "parallelstudios"
  }
}
