{
  "expo": {
    "name": "Realtor Portal",
    "slug": "realtor-portal",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.parallelstudios.realtorportal"
    },
    "android": {
      "package": "com.parallelstudios.realtorportal"
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-notifications",
      "expo-document-picker",
      "expo-image-picker"
    ],
    "scheme": "realtorportal"
  }
}
